<style>
  .footer {
    background-color: var(--green-deep);
    color: #ffffff;
    padding: 3rem 2rem 0;
    font-family: var(--font-body);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
    padding-bottom: 3rem;
  }

  .footer-col h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 1.25rem;
    font-family: var(--font-body);
    letter-spacing: 0;
  }

  .footer-col p {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.7;
    margin-bottom: 0.6rem;
  }

  .footer-small {
    font-size: 0.75rem !important;
    color: rgba(255, 255, 255, 0.65) !important;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .footer-nav a {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-nav a:hover {
    color: #ffffff;
    text-decoration: underline;
  }

  .footer-instagram {
    display: inline-block;
    margin-top: 1rem;
    color: rgba(255, 255, 255, 0.85);
    transition: color 0.2s;
  }

  .footer-instagram:hover {
    color: #ffffff;
  }

  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .footer-bottom p {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.85);
  }

  .footer-bottom-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-bottom-links a {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-bottom-links a:hover {
    color: #ffffff;
    text-decoration: underline;
  }

  /* 모바일 */
  @media (width <= 1023px) {
    .footer-inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (width <= 600px) {
    .footer {
      padding: 2.5rem 1.5rem 0;
    }

    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>
