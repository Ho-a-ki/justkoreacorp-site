---
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__brand">
      <span class="footer__logo">Just Korea Corp</span>
      <p class="footer__tagline">자연에서 온 건강한 생활</p>
    </div>

    <nav class="footer__nav">
      <ul>
        <li><a href="/activities">주요 활동</a></li>
        <li><a href="/stores">스토어</a></li>
        <li><a href="/hub">허브 백과사전</a></li>
        <li><a href="/guide">사용 가이드</a></li>
        <li><a href="/press">Press & Public</a></li>
        <li><a href="/contact">연락처</a></li>
      </ul>
    </nav>

    <div class="footer__external">
      <a href="#" target="_blank" rel="noopener" class="footer__ext-link">스파 →</a>
      <a href="#" target="_blank" rel="noopener" class="footer__ext-link">제품 찾기 →</a>
    </div>
  </div>

  <div class="footer__bottom container">
    <p>© {new Date().getFullYear()} Just Korea Corp. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--green-deep);
    color: var(--cream);
    padding: var(--spacing-lg) 0 var(--spacing-md);
    margin-top: auto;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--spacing-lg);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .footer__logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    display: block;
    margin-bottom: 0.5rem;
  }

  .footer__tagline {
    font-size: 0.8rem;
    color: var(--gold);
    letter-spacing: 0.1em;
  }

  .footer__nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer__nav a {
    font-size: 0.85rem;
    color: rgba(244, 239, 230, 0.6);
    transition: color 0.2s;
  }

  .footer__nav a:hover {
    color: var(--cream);
  }

  .footer__external {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer__ext-link {
    font-size: 0.85rem;
    color: var(--gold);
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .footer__ext-link:hover {
    opacity: 1;
  }

  .footer__bottom {
    padding-top: var(--spacing-md);
    font-size: 0.75rem;
    color: rgba(244, 239, 230, 0.3);
  }

  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }
  }
</style>
