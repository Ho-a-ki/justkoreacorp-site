<style>
  .footer {
    width: 100%;
    background-color: #00509e;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: auto;
    padding: 3rem 0;
    color: #ffffff;
    font-family: var(--font-body);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .footer-section h3 {
    margin: 0 0 1rem;
    font-size: 1.125rem;
    font-weight: bold;
    color: #ffffff;
    font-family: var(--font-body);
  }

  .footer-section p {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
  }

  .footer-nav a {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }

  .footer-nav a:hover {
    text-decoration: underline;
    color: #ffffff;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .social-icon {
    color: rgba(255, 255, 255, 0.8);
    transition: color 0.2s;
  }

  .social-links a:hover .social-icon {
    color: #ffffff;
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-bottom p {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
  }

  .footer-links {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    text-decoration: underline;
    color: #ffffff;
  }

  /* Accordion */
  .accordion-checkbox { display: none; }

  .accordion-header {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    color: inherit;
    margin-bottom: 1rem;
  }

  .accordion-header h3 { margin: 0; }

  .accordion-icon {
    position: relative;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .accordion-icon::before,
  .accordion-icon::after {
    content: '';
    position: absolute;
    background-color: #fff;
    transition: transform 0.3s ease;
  }

  .accordion-icon::before {
    width: 2px;
    height: 12px;
    top: 4px;
    left: 9px;
  }

  .accordion-icon::after {
    width: 12px;
    height: 2px;
    top: 9px;
    left: 4px;
  }

  .accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
  }

  .accordion-checkbox:checked + .accordion-header .accordion-icon::before {
    transform: rotate(90deg);
  }

  .accordion-checkbox:checked ~ .accordion-content {
    max-height: 500px;
    transition: max-height 0.5s ease-in;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .accordion-header { padding: 0.5rem 0; }
    .footer-section.accordion {
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    .footer-section.accordion:last-child { border-bottom: none; }
  }

  @media (min-width: 768px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
    .footer-links { margin-top: 0; }
    .accordion-header { pointer-events: none; }
    .accordion-icon { display: none; }
    .accordion-content { max-height: none; }
  }

  @media (min-width: 1024px) {
    .footer-grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
