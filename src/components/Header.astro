---
const navLinks = [
  { label: '주요 활동', href: '/activities' },
  { label: '스토어', href: '/stores' },
  { label: '허브 백과사전', href: '/hub' },
  { label: '사용 가이드', href: '/guide' },
  { label: 'Press & Public', href: '/press' },
  { label: '연락처', href: '/contact' },
];

const externalLinks = [
  { label: '스파', href: '#' },
  { label: '제품 찾기', href: '#' },
];

const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="header__inner container">
    <a href="/" class="header__logo">
      <span class="header__logo-text">Just Korea</span>
      <span class="header__logo-sub">Corp</span>
    </a>

    <nav class="header__nav" id="nav">
      <ul class="header__nav-list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`header__nav-link ${currentPath === link.href || currentPath.startsWith(link.href + '/') ? 'is-active' : ''}`}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li class="header__nav-divider"></li>
        {externalLinks.map(link => (
          <li>
            <a href={link.href} class="header__nav-link header__nav-link--external" target="_blank" rel="noopener">
              {link.label}
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                <path d="M1 9L9 1M9 1H3M9 1V7" stroke="currentColor" stroke-width="1.2"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button class="header__menu-btn" id="menuBtn" aria-label="메뉴 열기">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    background-color: var(--green-deep);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    transition: background-color 0.3s;
  }

  .header__inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
  }

  .header__logo {
    display: flex;
    align-items: baseline;
    gap: 0.3em;
    flex-shrink: 0;
  }

  .header__logo-text {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--cream);
    letter-spacing: 0.02em;
  }

  .header__logo-sub {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 300;
    color: var(--gold);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .header__nav-list {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }

  .header__nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    padding: 0.4em 0.8em;
    font-size: 0.8rem;
    font-weight: 400;
    color: rgba(244, 239, 230, 0.7);
    letter-spacing: 0.05em;
    border-radius: 2px;
    transition: color 0.2s, background-color 0.2s;
    white-space: nowrap;
  }

  .header__nav-link:hover,
  .header__nav-link.is-active {
    color: var(--cream);
    background-color: rgba(255,255,255,0.07);
  }

  .header__nav-link.is-active {
    color: var(--gold-light);
  }

  .header__nav-link--external {
    color: rgba(184, 146, 74, 0.7);
  }

  .header__nav-link--external:hover {
    color: var(--gold);
    background-color: rgba(184, 146, 74, 0.1);
  }

  .header__nav-divider {
    width: 1px;
    height: 16px;
    background-color: rgba(255,255,255,0.15);
    margin: 0 0.5rem;
  }

  .header__menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .header__menu-btn span {
    display: block;
    width: 24px;
    height: 1.5px;
    background-color: var(--cream);
    transition: transform 0.3s;
  }

  @media (max-width: 1024px) {
    .header__nav {
      display: none;
      position: fixed;
      top: var(--nav-height);
      left: 0;
      right: 0;
      background-color: var(--green-deep);
      padding: var(--spacing-md);
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    .header__nav.is-open {
      display: block;
    }

    .header__nav-list {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
    }

    .header__nav-link {
      padding: 0.8em 0.5em;
      font-size: 1rem;
      width: 100%;
    }

    .header__nav-divider {
      width: 100%;
      height: 1px;
      margin: 0.5rem 0;
    }

    .header__menu-btn {
      display: flex;
    }
  }
</style>

<script>
  const btn = document.getElementById('menuBtn');
  const nav = document.getElementById('nav');
  btn?.addEventListener('click', () => {
    nav?.classList.toggle('is-open');
  });
</script>
