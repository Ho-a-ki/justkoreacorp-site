---
export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Just Korea Corp', description = '자연에서 온 건강한 생활' } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Just Korea Corp</title>
    <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@600&display=swap" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --green-deep: #00509e;
    --green-mid: #0066cc;
    --green-light: #3388dd;
    --cream: #f0f6ff;
    --cream-dark: #d6e8f7;
    --gold: #D2AC53;
    --gold-light: #e0c070;
    --charcoal: #1C1C1C;
    --gray: #6B6B6B;
    --white: #ffffff;

    --font-display: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, system-ui;
    --font-body: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, system-ui;

    --spacing-xs: 0.5rem;
    --spacing-sm: 1rem;
    --spacing-md: 2rem;
    --spacing-lg: 4rem;
    --spacing-xl: 8rem;

    --max-width: 1280px;
    --nav-height: 110px;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-body);
    background-color: var(--white);
    color: var(--charcoal);
    font-weight: 300;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  body.menu-open {
    overflow: hidden;
  }

  h1, h2, h3, h4 {
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  .section {
    padding: var(--spacing-xl) 0;
  }

  .section--green,
  .section--blue {
    background-color: var(--green-deep);
    color: var(--cream);
  }

  .section--cream {
    background-color: var(--cream);
  }

  .page-hero {
    padding: calc(var(--nav-height) + var(--spacing-xl)) 0 var(--spacing-xl);
    background-color: var(--green-deep);
    color: var(--cream);
  }

  .page-hero__label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: var(--spacing-sm);
  }

  .page-hero__title {
    font-size: clamp(3rem, 8vw, 6rem);
    margin-bottom: var(--spacing-sm);
  }

  .page-hero__desc {
    font-size: 1.1rem;
    color: var(--cream-dark);
    max-width: 540px;
    font-weight: 300;
  }

  @media (width <= 1024px) {
    :root {
      --nav-height: 80px;
    }
  }

  @media (width <= 768px) {
    :root {
      --spacing-lg: 2.5rem;
      --spacing-xl: 4rem;
    }

    .container {
      padding: 0 1rem;
    }
  }
</style>
