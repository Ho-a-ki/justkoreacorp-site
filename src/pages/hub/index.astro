---
import { Client } from '@notionhq/client';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const notion = new Client({ auth: import.meta.env.NOTION_API_KEY });

const DATA_SOURCE_ID = '4f6d8d03-3a27-4cca-9007-06004a532702';

const response = await notion.dataSources.query({
  data_source_id: DATA_SOURCE_ID,
  sorts: [{ property: '이름', direction: 'ascending' }],
});

const herbs = response.results.map((page: any) => {
  const props = page.properties;
  return {
    id: page.id,
    url: page.url,
    name: props['이름']?.title?.[0]?.plain_text ?? '',
    tags: props['태그']?.multi_select?.map((t: any) => t.name) ?? [],
  };
});
---

<BaseLayout title="허브 백과사전" description="다양한 허브의 효능과 특성을 알아보세요.">
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="page-hero__label">Herb Encyclopedia</p>
        <h1 class="page-hero__title">허브 백과사전</h1>
        <p class="page-hero__desc">자연이 품은 허브의 이야기, 효능, 그리고 활용법을 소개합니다.</p>
      </div>
    </section>

    <section class="section section--cream">
      <div class="container">
        {herbs.length === 0 ? (
          <p class="empty">등록된 허브가 없습니다.</p>
        ) : (
          <div class="hub-grid">
            {herbs.map(herb => (
              <a href={`/hub/${herb.id}`} class="herb-card">
                <div class="herb-card__icon">✦</div>
                <div class="herb-card__tags">
                  {herb.tags.map((tag: string) => (
                    <span class="herb-card__tag">{tag}</span>
                  ))}
                </div>
                <h3 class="herb-card__name">{herb.name}</h3>
                <span class="herb-card__link">자세히 보기 →</span>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .hub-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .herb-card {
    background-color: var(--white);
    border: 1px solid var(--cream-dark);
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s, transform 0.2s;
    text-decoration: none;
  }

  .herb-card:hover {
    border-color: var(--green-light);
    transform: translateY(-4px);
  }

  .herb-card__icon {
    font-size: 1.5rem;
    color: var(--gold);
  }

  .herb-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    min-height: 1.2rem;
  }

  .herb-card__tag {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green-mid);
    background-color: var(--cream);
    padding: 0.2em 0.6em;
    border-radius: 2px;
    font-weight: 500;
  }

  .herb-card__name {
    font-size: 1.5rem;
    color: var(--green-deep);
    flex: 1;
  }

  .herb-card__link {
    font-size: 0.82rem;
    color: var(--green-mid);
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.1em;
    display: inline-block;
    transition: color 0.2s;
  }

  .herb-card:hover .herb-card__link {
    color: var(--gold);
  }

  .empty {
    color: var(--gray);
    font-size: 0.95rem;
  }

  @media (max-width: 1024px) {
    .hub-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .hub-grid { grid-template-columns: 1fr; }
  }
</style>
