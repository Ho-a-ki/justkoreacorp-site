---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import faq from '../data/faq.json';
---

<BaseLayout title="FAQ" description="유스트코리아에 대해 자주 묻는 질문과 답변입니다.">
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="page-hero__label">FAQ</p>
        <h1 class="page-hero__title">자주 묻는 질문</h1>
        <p class="page-hero__desc">유스트코리아 제품과 서비스에 대한 궁금증을 해결해보세요.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="faq-wrap">
          {faq.map(cat => (
            <div class="faq-category">
              <h2 class="faq-category__title">{cat.category}</h2>
              <div class="faq-list">
                {cat.items.map(item => (
                  <details class="faq-item">
                    <summary class="faq-item__question">{item.question}</summary>
                    <div class="faq-item__answer" set:html={item.answer} />
                  </details>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .faq-wrap {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .faq-category__title {
    font-size: 1.3rem;
    color: var(--green-deep);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--green-deep);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-bottom: 1px solid var(--cream-dark);
  }

  .faq-item__question {
    padding: 1.2rem 0;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--charcoal);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .faq-item__question::-webkit-details-marker {
    display: none;
  }

  .faq-item__question::after {
    content: '+';
    font-size: 1.4rem;
    font-weight: 300;
    color: var(--gray);
    flex-shrink: 0;
  }

  .faq-item[open] .faq-item__question::after {
    content: '−';
  }

  .faq-item__question:hover {
    color: var(--green-mid);
  }

  .faq-item__answer {
    padding: 0 0 1.5rem;
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--gray);
  }

  .faq-item__answer :global(p) { margin-bottom: 0.8rem; }
  .faq-item__answer :global(ul), .faq-item__answer :global(ol) { padding-left: 1.5rem; margin-bottom: 0.8rem; }
  .faq-item__answer :global(strong) { color: var(--charcoal); }
  .faq-item__answer :global(a) { color: var(--green-mid); text-decoration: underline; }
  .faq-item__answer :global(figure) { margin: 1rem 0; }
  .faq-item__answer :global(img) { max-width: 100%; border-radius: 4px; }
  .faq-item__answer :global(blockquote) { border-left: 3px solid var(--gold); padding: 0.5rem 1rem; margin: 0.8rem 0; background-color: var(--cream); color: var(--gray); }
  .faq-item__answer :global(table) { width: 100%; border-collapse: collapse; margin: 0.8rem 0; font-size: 0.85rem; }
  .faq-item__answer :global(th), .faq-item__answer :global(td) { border: 1px solid var(--cream-dark); padding: 0.6rem 0.8rem; text-align: left; }
  .faq-item__answer :global(th) { background-color: var(--cream); font-weight: 600; color: var(--charcoal); }
  .faq-item__answer :global(.callout) { background-color: var(--cream); border-left: 3px solid var(--green-mid); padding: 0.8rem 1rem; margin: 0.6rem 0; border-radius: 0 4px 4px 0; }
</style>
