---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="주요 활동" description="저스트코리아의 주요 활동과 사업 영역을 소개합니다.">
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="page-hero__label">Activities</p>
        <h1 class="page-hero__title">주요 활동</h1>
        <p class="page-hero__desc">저스트코리아가 만들어가는 다양한 활동과 사업 영역을 소개합니다.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="activity-grid">
          <div class="activity-item">
            <span class="activity-item__num">01</span>
            <h2 class="activity-item__title">제품 개발</h2>
            <p class="activity-item__desc">자연 허브 원료를 기반으로 한 건강 제품 연구 및 개발</p>
          </div>
          <div class="activity-item">
            <span class="activity-item__num">02</span>
            <h2 class="activity-item__title">교육 및 세미나</h2>
            <p class="activity-item__desc">허브와 자연 건강법에 대한 교육 프로그램 운영</p>
          </div>
          <div class="activity-item">
            <span class="activity-item__num">03</span>
            <h2 class="activity-item__title">커뮤니티</h2>
            <p class="activity-item__desc">건강한 생활을 지향하는 사람들과의 커뮤니티 활동</p>
          </div>
          <div class="activity-item">
            <span class="activity-item__num">04</span>
            <h2 class="activity-item__title">파트너십</h2>
            <p class="activity-item__desc">국내외 건강 브랜드 및 전문가와의 협력 활동</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .activity-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background-color: var(--cream-dark);
    border: 1px solid var(--cream-dark);
    margin-top: 2rem;
  }

  .activity-item {
    background-color: var(--white);
    padding: 3rem;
    transition: background-color 0.2s;
  }

  .activity-item:hover {
    background-color: var(--cream);
  }

  .activity-item__num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--gold);
    font-style: italic;
    display: block;
    margin-bottom: 1rem;
  }

  .activity-item__title {
    font-size: 1.6rem;
    color: var(--green-deep);
    margin-bottom: 1rem;
  }

  .activity-item__desc {
    font-size: 0.95rem;
    color: var(--gray);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .activity-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
