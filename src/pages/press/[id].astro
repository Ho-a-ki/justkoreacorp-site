---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import pressItems from '../../data/press.json';
import celebItems from '../../data/celeb.json';

const allItems = [...pressItems, ...celebItems];

export function getStaticPaths() {
  const press = import('../../data/press.json').then(m => m.default);
  const celeb = import('../../data/celeb.json').then(m => m.default);
  return Promise.all([press, celeb]).then(([p, c]) =>
    [...p, ...c].map(item => ({ params: { id: item.id } }))
  );
}

const { id } = Astro.params;
const item = allItems.find(i => i.id === id)!;
---

<BaseLayout title={item.name} description={`${item.name} — 미디어`}>
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <a href="/press" class="back-link">← 미디어</a>
        <div class="hero-tags">
          {item.tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
        <h1 class="page-hero__title">{item.name}</h1>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="press-content" set:html={item.content} />
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.82rem;
    color: rgba(244, 239, 230, 0.6);
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--cream); }

  .hero-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .tag {
    font-size: 0.7rem;
    padding: 0.2em 0.8em;
    border: 1px solid rgba(184, 146, 74, 0.4);
    color: var(--gold);
    border-radius: 2px;
    letter-spacing: 0.08em;
  }

  .press-content {
    max-width: 720px;
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.9;
    color: var(--charcoal);
  }

  .press-content :global(h2) { font-size: 1.8rem; color: var(--green-deep); margin: 2.5rem 0 1rem; font-family: var(--font-display); }
  .press-content :global(h3) { font-size: 1.4rem; color: var(--green-deep); margin: 2rem 0 0.75rem; font-family: var(--font-display); }
  .press-content :global(h4) { font-size: 1.1rem; color: var(--green-deep); margin: 1.5rem 0 0.5rem; }
  .press-content :global(p) { margin-bottom: 1.2rem; color: var(--charcoal); }
  .press-content :global(ul), .press-content :global(ol) { padding-left: 1.5rem; margin-bottom: 1.2rem; }
  .press-content :global(li) { margin-bottom: 0.4rem; }
  .press-content :global(blockquote) { border-left: 3px solid var(--gold); padding: 0.75rem 1.5rem; margin: 1.5rem 0; background-color: var(--cream); color: var(--gray); }
  .press-content :global(hr) { border: none; border-top: 1px solid var(--cream-dark); margin: 2rem 0; }
  .press-content :global(figure) { margin: 2rem 0; }
  .press-content :global(img) { width: 100%; border-radius: 4px; }
  .press-content :global(figcaption) { font-size: 0.82rem; color: var(--gray); text-align: center; margin-top: 0.5rem; }
  .press-content :global(code) { background-color: var(--cream); padding: 0.1em 0.4em; border-radius: 2px; font-size: 0.9em; }
  .press-content :global(.callout) { background-color: var(--cream); border-left: 3px solid var(--green-mid); padding: 1rem 1.5rem; margin: 1.5rem 0; border-radius: 0 4px 4px 0; }
  .press-content :global(a) { color: var(--green-mid); text-decoration: underline; }
</style>
