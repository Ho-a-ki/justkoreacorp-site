---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import pressItems from '../../data/press.json';
import celebItems from '../../data/celeb.json';
---

<BaseLayout title="미디어" description="유스트코리아의 미디어 노출 및 셀럽 활동을 소개합니다.">
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="page-hero__label">Media</p>
        <h1 class="page-hero__title">미디어</h1>
        <p class="page-hero__desc">미디어, 유튜브, 인플루언서와 함께하는 유스트코리아의 이야기</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section-heading">Press</h2>
        {pressItems.length === 0 ? (
          <p class="empty">등록된 Press 항목이 없습니다.</p>
        ) : (
          <div class="press-grid">
            {pressItems.map(item => (
              <a href={`/press/${item.id}`} class="press-card">
                <div class="press-card__thumb">
                  <span class="material-symbols-outlined press-card__icon">article</span>
                  {item.thumbnail && (
                    <img src={item.thumbnail} alt={item.name} loading="lazy" decoding="async" class="press-card__img" />
                  )}
                </div>
                <div class="press-card__body">
                  <h3 class="press-card__title">{item.name}</h3>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>

    <section class="section section--cream">
      <div class="container">
        <h2 class="section-heading">유스트를 사용하는 셀럽</h2>
        {celebItems.length === 0 ? (
          <p class="empty">등록된 셀럽 항목이 없습니다.</p>
        ) : (
          <div class="press-grid">
            {celebItems.map(item => (
              <a
                href={item.url || `/press/${item.id}`}
                class="press-card"
                target={item.url ? '_blank' : undefined}
                rel={item.url ? 'noopener' : undefined}
              >
                <div class="press-card__thumb">
                  <span class="material-symbols-outlined press-card__icon">article</span>
                  {item.thumbnail && (
                    <img src={item.thumbnail} alt={item.name} loading="lazy" decoding="async" class="press-card__img" />
                  )}
                </div>
                <div class="press-card__body">
                  <h3 class="press-card__title">{item.name}</h3>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .section-heading {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--green-deep);
    margin-bottom: 2rem;
  }

  .press-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.2rem;
  }

  .press-card {
    border: 1px solid var(--cream-dark);
    background: var(--white);
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }

  .press-card:hover {
    border-color: var(--green-mid);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }

  .press-card__thumb {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: var(--cream);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .press-card__icon {
    font-size: 3rem;
    color: var(--green-mid);
    opacity: 0.3;
  }

  .press-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .press-card:hover .press-card__img {
    transform: scale(1.05);
    transition: transform 0.3s ease;
  }

  .press-card__body {
    padding: 1rem 1.2rem;
  }

  .press-card__title {
    font-size: 0.9rem;
    color: var(--green-deep);
    line-height: 1.5;
  }

  .empty {
    color: var(--gray);
    font-size: 0.95rem;
  }

  @media (width <= 1024px) {
    .press-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (width <= 768px) {
    .press-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (width <= 480px) {
    .press-grid { grid-template-columns: 1fr; }
  }
</style>
