---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="홈" description="Just Korea Corp — 자연에서 온 건강한 생활">
  <Header />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero__bg"></div>
      <div class="hero__content container">
        <p class="hero__label">Just Korea Corp</p>
        <h1 class="hero__title">자연이 전하는<br /><em>건강한 삶</em></h1>
        <p class="hero__desc">허브의 힘으로 더 건강하고 풍요로운 생활을 만들어갑니다.</p>
        <div class="hero__actions">
          <a href="/hub" class="btn btn--primary">허브 백과사전</a>
          <a href="/about" class="btn btn--ghost">브랜드 소개 →</a>
        </div>
      </div>
      <div class="hero__scroll">
        <span>Scroll</span>
        <div class="hero__scroll-line"></div>
      </div>
    </section>

    <!-- Brand intro -->
    <section class="section intro">
      <div class="container intro__grid">
        <div class="intro__text">
          <p class="section-label">About</p>
          <h2 class="section-title">자연과 사람을<br />잇는 브랜드</h2>
          <p class="section-body">저스트코리아는 자연에서 얻은 허브의 가치를 현대적인 방식으로 전달합니다. 엄선된 원료와 과학적 연구를 바탕으로, 누구나 더 건강한 일상을 누릴 수 있도록 돕습니다.</p>
          <a href="/activities" class="text-link">주요 활동 보기 →</a>
        </div>
        <div class="intro__visual">
          <div class="intro__card">
            <div class="intro__card-inner">
              <span class="intro__card-num">01</span>
              <span class="intro__card-label">자연 원료</span>
            </div>
          </div>
          <div class="intro__card intro__card--offset">
            <div class="intro__card-inner">
              <span class="intro__card-num">02</span>
              <span class="intro__card-label">과학적 연구</span>
            </div>
          </div>
          <div class="intro__card">
            <div class="intro__card-inner">
              <span class="intro__card-num">03</span>
              <span class="intro__card-label">건강한 생활</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick links -->
    <section class="section section--cream quicklinks">
      <div class="container">
        <p class="section-label">탐색하기</p>
        <h2 class="section-title">Just Korea와<br />함께하세요</h2>
        <div class="quicklinks__grid">
          <a href="/hub" class="ql-card">
            <span class="ql-card__num">01</span>
            <h3 class="ql-card__title">허브 백과사전</h3>
            <p class="ql-card__desc">다양한 허브의 효능과 사용법을 알아보세요.</p>
            <span class="ql-card__arrow">→</span>
          </a>
          <a href="/guide" class="ql-card">
            <span class="ql-card__num">02</span>
            <h3 class="ql-card__title">사용 가이드</h3>
            <p class="ql-card__desc">제품을 올바르게 활용하는 방법을 안내합니다.</p>
            <span class="ql-card__arrow">→</span>
          </a>
          <a href="/stores" class="ql-card">
            <span class="ql-card__num">03</span>
            <h3 class="ql-card__title">스토어 안내</h3>
            <p class="ql-card__desc">가까운 저스트코리아 스토어를 찾아보세요.</p>
            <span class="ql-card__arrow">→</span>
          </a>
          <a href="/press" class="ql-card">
            <span class="ql-card__num">04</span>
            <h3 class="ql-card__title">Press & Public</h3>
            <p class="ql-card__desc">미디어 노출 및 인플루언서 활동을 확인하세요.</p>
            <span class="ql-card__arrow">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Contact CTA -->
    <section class="section section--green cta">
      <div class="container cta__inner">
        <div>
          <p class="section-label" style="color: var(--gold)">협업 문의</p>
          <h2 class="section-title" style="color: var(--cream)">함께 만들어가요</h2>
        </div>
        <a href="/contact" class="btn btn--gold">문의하기</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background-color: var(--green-deep);
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 80% at 80% 50%, rgba(45, 89, 65, 0.4) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 20% 80%, rgba(184, 146, 74, 0.08) 0%, transparent 60%);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding-top: var(--nav-height);
  }

  .hero__label {
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
    font-weight: 400;
  }

  .hero__title {
    font-size: clamp(3.5rem, 9vw, 7rem);
    color: var(--cream);
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  .hero__title em {
    font-style: italic;
    color: var(--gold-light);
  }

  .hero__desc {
    font-size: 1.1rem;
    color: rgba(244, 239, 230, 0.65);
    max-width: 460px;
    margin-bottom: 3rem;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    right: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .hero__scroll span {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(244, 239, 230, 0.3);
    writing-mode: vertical-rl;
  }

  .hero__scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, rgba(244,239,230,0.3), transparent);
    animation: scrollLine 2s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0%, 100% { transform: scaleY(1); opacity: 1; }
    50% { transform: scaleY(0.5); opacity: 0.4; }
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 0.9em 2em;
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    border-radius: 2px;
    transition: all 0.2s;
    cursor: pointer;
  }

  .btn--primary {
    background-color: var(--gold);
    color: var(--green-deep);
  }

  .btn--primary:hover {
    background-color: var(--gold-light);
  }

  .btn--ghost {
    border: 1px solid rgba(244, 239, 230, 0.3);
    color: var(--cream);
  }

  .btn--ghost:hover {
    border-color: var(--cream);
    background-color: rgba(255,255,255,0.05);
  }

  .btn--gold {
    background-color: var(--gold);
    color: var(--green-deep);
    font-weight: 500;
  }

  .btn--gold:hover {
    background-color: var(--gold-light);
  }

  /* Labels & typography */
  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
    font-weight: 400;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 1.5rem;
    color: var(--green-deep);
  }

  .section-body {
    font-size: 1rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 480px;
    margin-bottom: 2rem;
  }

  .text-link {
    font-size: 0.9rem;
    color: var(--green-mid);
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.1em;
    transition: color 0.2s;
  }

  .text-link:hover {
    color: var(--gold);
  }

  /* Intro section */
  .intro__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .intro__visual {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .intro__card {
    background-color: var(--cream);
    border: 1px solid var(--cream-dark);
    border-radius: 4px;
    padding: 1.5rem 2rem;
    transition: transform 0.2s;
  }

  .intro__card:hover {
    transform: translateX(8px);
  }

  .intro__card--offset {
    margin-left: 2rem;
    background-color: var(--green-deep);
    border-color: var(--green-mid);
  }

  .intro__card--offset .intro__card-num,
  .intro__card--offset .intro__card-label {
    color: var(--cream);
  }

  .intro__card-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .intro__card-num {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--gold);
    font-style: italic;
    line-height: 1;
  }

  .intro__card-label {
    font-size: 0.9rem;
    color: var(--charcoal);
    letter-spacing: 0.05em;
  }

  /* Quick links */
  .quicklinks__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background-color: var(--cream-dark);
    border: 1px solid var(--cream-dark);
    margin-top: 3rem;
  }

  .ql-card {
    background-color: var(--cream);
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: background-color 0.2s;
    position: relative;
  }

  .ql-card:hover {
    background-color: var(--green-deep);
    color: var(--cream);
  }

  .ql-card:hover .ql-card__desc {
    color: rgba(244,239,230,0.6);
  }

  .ql-card__num {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--gold);
    font-style: italic;
  }

  .ql-card__title {
    font-size: 1.1rem;
    font-weight: 400;
  }

  .ql-card__desc {
    font-size: 0.82rem;
    color: var(--gray);
    line-height: 1.6;
    flex: 1;
  }

  .ql-card__arrow {
    font-size: 1.2rem;
    color: var(--gold);
  }

  /* CTA */
  .cta__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
  }

  .cta__inner .section-title {
    color: var(--cream);
    margin-bottom: 0;
  }

  @media (max-width: 1024px) {
    .quicklinks__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .intro__grid {
      grid-template-columns: 1fr;
    }

    .quicklinks__grid {
      grid-template-columns: 1fr;
    }

    .cta__inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
