---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="홈" description="JUST Korea — 스위스 알프스 허브의 힘">
  <Header />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero__bg"></div>
      <div class="hero__overlay"></div>
      <div class="hero__content container">
        <p class="hero__label">유스트 — 1930년부터 이어져 온 오리지널 브랜드</p>
        <h1 class="hero__title">Appenzell Herbal Power<br />for the Whole World</h1>
        <p class="hero__subtitle">아펜첼 허브의 힘이 전 세계에 전해집니다</p>
        <div class="hero__actions">
          <a href="/stores" class="btn btn--hero">스토어 바로가기</a>
        </div>
      </div>
      <div class="hero__scroll">
        <span>스크롤</span>
        <div class="hero__scroll-line"></div>
      </div>
    </section>

    <!-- Brand Story -->
    <section class="section brand">
      <div class="container brand__grid">
        <div class="brand__text">
          <p class="section-label">About JUST Korea</p>
          <h2 class="section-title">스위스 허브를<br />한국에 전하다</h2>
          <p class="section-body">유스트코리아는 스위스 JUST의 한국 공식 법인입니다. 스위스 본사에서 직접 수입한 천연 허브 제품을 한국 고객에게 전달하며, 스파·직영 매장·온라인을 통해 허브의 가치를 전하고 있습니다.</p>
          <a href="/activities" class="text-link">주요 활동 보기 →</a>
        </div>
        <div class="brand__visual">
          <div class="brand__card">
            <span class="brand__card-icon material-symbols-outlined">verified</span>
            <div>
              <strong>ISO 3종 인증</strong>
              <p>품질·GMP·환경 국제 인증</p>
            </div>
          </div>
          <div class="brand__card">
            <span class="brand__card-icon material-symbols-outlined">science</span>
            <div>
              <strong>연간 7,500건 품질검사</strong>
              <p>원료부터 완제품까지 정밀 테스트</p>
            </div>
          </div>
          <div class="brand__card">
            <span class="brand__card-icon material-symbols-outlined">cruelty_free</span>
            <div>
              <strong>동물실험 절대 불가</strong>
              <p>창립 이래 일관된 원칙</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Herbs -->
    <section class="section herbs">
      <div class="container">
        <div class="herbs__header">
          <p class="section-label">강력한 허브</p>
          <h2 class="section-title">스위스의 전통 약초와 과학의 만남</h2>
          <p class="section-body">독특한 식물 추출물과 강력한 에센스는 자연이 준 놀라운 선물입니다. JUST는 풍부한 경험과 지식을 바탕으로 스위스 고유의 허브와 전 세계 최고급 원료를 사용하여 높은 효능을 구현합니다.</p>
        </div>
        <div class="herbs__grid">
          {[
            { name: '에델바이스', desc: '항산화, 피부 보호', img: '/images/herbs/edelweiss.png' },
            { name: '세이지', desc: '항균, 소염 작용', img: '/images/herbs/sage.png' },
            { name: '백리향', desc: '항바이러스, 면역 강화', img: '/images/herbs/thyme.png' },
            { name: '티트리', desc: '살균, 피부 진정', img: '/images/herbs/teatree.png' },
            { name: '말로우', desc: '보습, 피부 연화', img: '/images/herbs/mallow.png' },
            { name: '레몬밤', desc: '진정, 스트레스 완화', img: '/images/herbs/lemonbalm.png' },
            { name: '향나무', desc: '혈액순환, 근육 이완', img: '/images/herbs/juniper.png' },
            { name: '유칼립투스', desc: '호흡기 케어, 청량감', img: '/images/herbs/eucalyptus.png' },
          ].map(herb => (
            <a href="/herb" class="herb-card">
              <div class="herb-card__circle">
                <img src={herb.img} alt={herb.name} loading="lazy" decoding="async" />
              </div>
              <strong class="herb-card__name">{herb.name}</strong>
              <span class="herb-card__desc">{herb.desc}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Product Philosophy -->
    <section class="section philosophy">
      <div class="container philosophy__layout">
        <div class="philosophy__text">
          <p class="section-label">제품 철학</p>
          <h2 class="section-title">순수한 식물의 힘으로<br />특별한 자연 속 웰빙을<br />느껴보세요</h2>
          <p class="section-body">JUST는 건강, 아름다움, 그리고 웰빙을 위한 독창적이고 뛰어난 효능의 스킨케어 제품을 개발 및 생산합니다. 과학과 연구를 통해 완성된 식물과 허브의 탁월한 효능으로 고객 만족을 최우선으로 생각합니다.</p>
          <p class="section-body">JUST 제품은 '스위스에서 제조' 되었으며 스위스 국기를 달고 있습니다. 스위스 제품의 높은 품질 기준을 충족하며, 발첸하우젠에 위치한 자체 연구소에서 개발되고 최첨단 생산 시설에서 제조됩니다.</p>
          <a href="/faq" class="btn btn--primary">더 알아보기</a>
        </div>
        <div class="philosophy__images">
          <div class="phi-img phi-img--main">
            <img src="/images/philosophy/flowers.jpg" alt="스위스 알프스 에델바이스" loading="lazy" />
          </div>
          <div class="phi-img phi-img--overlay">
            <img src="/images/philosophy/rose-cream.png" alt="로즈 크림 제품" loading="lazy" />
          </div>
        </div>
      </div>
      <div class="container philosophy__gallery">
        <div class="phi-img phi-img--bottle">
          <img src="/images/philosophy/oil-bottle.png" alt="31 허브 오일" loading="lazy" />
        </div>
        <div class="phi-img phi-img--scientist">
          <img src="/images/philosophy/scientist.jpg" alt="품질 연구원" loading="lazy" />
        </div>
        <div class="phi-img phi-img--edelweiss">
          <img src="/images/philosophy/edelweiss-close.jpg" alt="에델바이스 클로즈업" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- Quick Links -->
    <section class="section quicklinks">
      <div class="container">
        <p class="section-label">탐색하기</p>
        <h2 class="section-title">더 알아보세요</h2>
        <div class="quicklinks__grid">
          <a href="/herb" class="ql-card">
            <span class="material-symbols-outlined ql-card__icon">spa</span>
            <h3 class="ql-card__title">허브 백과사전</h3>
            <p class="ql-card__desc">다양한 허브의 효능과 사용법</p>
          </a>
          <a href="/faq" class="ql-card">
            <span class="material-symbols-outlined ql-card__icon">help</span>
            <h3 class="ql-card__title">FAQ</h3>
            <p class="ql-card__desc">자주 묻는 질문과 답변</p>
          </a>
          <a href="/stores" class="ql-card">
            <span class="material-symbols-outlined ql-card__icon">storefront</span>
            <h3 class="ql-card__title">스토어</h3>
            <p class="ql-card__desc">가까운 스토어 찾기</p>
          </a>
          <a href="/press" class="ql-card">
            <span class="material-symbols-outlined ql-card__icon">newspaper</span>
            <h3 class="ql-card__title">Press & Public</h3>
            <p class="ql-card__desc">미디어 및 셀럽 소식</p>
          </a>
        </div>
      </div>
    </section>

    <!-- Contact CTA -->
    <section class="section section--cream cta">
      <div class="container cta__inner">
        <div>
          <p class="section-label">Contact</p>
          <h2 class="section-title">궁금한 점이 있으신가요?</h2>
          <p class="section-body">제품, 협업, 비즈니스 파트너십 등 어떤 문의든 환영합니다.</p>
        </div>
        <a href="/contact" class="btn btn--primary btn--lg">문의하기</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Hero - full background image */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background: url('/images/hero/banner.jpg') center/cover no-repeat;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.15) 50%, rgba(0,0,0,0.4) 100%);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding-top: var(--nav-height);
  }

  .hero__label {
    font-size: 0.82rem;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.85);
    margin-bottom: 1.5rem;
    font-weight: 400;
  }

  .hero__title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    color: #fff;
    margin-bottom: 2rem;
    line-height: 1.2;
    font-weight: 800;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }

  .hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: rgba(255,255,255,0.8);
    margin-bottom: 2rem;
    font-weight: 400;
    letter-spacing: 0.05em;
  }

  .hero__actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }

  .btn--hero {
    display: inline-block;
    padding: 1em 2.5em;
    font-size: 0.9rem;
    font-weight: 600;
    background: var(--green-mid);
    color: #fff;
    border-radius: 50px;
    transition: background 0.2s;
    text-decoration: none;
  }

  .btn--hero:hover {
    background: var(--green-deep);
  }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .hero__scroll span {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.5);
  }

  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent);
    animation: scrollLine 2s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0%, 100% { transform: scaleY(1); opacity: 1; }
    50% { transform: scaleY(0.5); opacity: 0.4; }
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 0.9em 2em;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    border-radius: 4px;
    transition: all 0.2s;
    cursor: pointer;
    text-decoration: none;
  }

  .btn--primary {
    background-color: var(--green-mid);
    color: #fff;
    border-radius: 50px;
  }

  .btn--primary:hover {
    background-color: var(--green-deep);
  }

  .btn--lg {
    padding: 1.1em 3em;
    font-size: 0.95rem;
  }

  /* Typography */
  .section-label {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--green-mid);
    margin-bottom: 0.8rem;
    font-weight: 600;
  }

  .section-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    margin-bottom: 1.2rem;
    color: var(--green-deep);
    font-weight: 700;
    line-height: 1.3;
  }

  .section-body {
    font-size: 0.95rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 520px;
    margin-bottom: 1.5rem;
  }

  .text-link {
    font-size: 0.88rem;
    color: var(--green-mid);
    font-weight: 500;
    transition: color 0.2s;
  }

  .text-link:hover { color: var(--green-deep); }

  /* Brand */
  .brand__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .brand__visual { display: flex; flex-direction: column; gap: 1rem; }

  .brand__card {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1.5rem 1.8rem;
    background: var(--cream);
    border: 1px solid var(--cream-dark);
    border-radius: 8px;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .brand__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }

  .brand__card-icon { font-size: 2rem; color: var(--green-mid); flex-shrink: 0; }
  .brand__card strong { display: block; font-size: 0.92rem; color: var(--charcoal); margin-bottom: 0.2rem; }
  .brand__card p { font-size: 0.8rem; color: var(--gray); }

  /* Herbs */
  .herbs { background-color: #e8eef6; }

  .herbs__header { margin-bottom: 3rem; }

  .herbs__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .herb-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.8rem;
    text-decoration: none;
    transition: transform 0.2s;
  }

  .herb-card:hover { transform: translateY(-4px); }

  .herb-card__circle {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    background: rgba(160, 180, 210, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: transform 0.3s;
  }

  .herb-card:hover .herb-card__circle {
    transform: scale(1.06);
  }

  .herb-card__circle img {
    width: 120%;
    height: 120%;
    object-fit: contain;
  }

  .herb-card__name {
    font-size: 0.95rem;
    color: var(--charcoal);
  }

  .herb-card__desc {
    font-size: 0.78rem;
    color: var(--gray);
  }

  /* Philosophy */
  .philosophy__layout {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--spacing-lg);
    align-items: start;
    margin-bottom: 3rem;
  }

  .philosophy__images {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    position: relative;
  }

  .phi-img { border-radius: 8px; overflow: hidden; }
  .phi-img img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .phi-img--main { height: 360px; }

  .phi-img--overlay {
    position: absolute;
    top: -20px;
    right: -10px;
    width: 180px;
    z-index: 1;
  }

  .phi-img--overlay img {
    object-fit: contain;
    filter: drop-shadow(0 4px 16px rgba(0,0,0,0.12));
  }

  .philosophy__gallery {
    display: grid;
    grid-template-columns: 200px 1fr 1fr;
    gap: 1.5rem;
    align-items: end;
  }

  .phi-img--bottle img { object-fit: contain; }
  .phi-img--scientist { height: 280px; }
  .phi-img--edelweiss { height: 230px; }

  /* Stats */
  .stats__grid {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    margin-top: 3rem;
    flex-wrap: wrap;
  }

  .stat { text-align: center; flex: 1; min-width: 120px; }

  .stat__number {
    display: block;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 700;
    color: var(--cream);
    margin-bottom: 0.3rem;
  }

  .stat__label {
    font-size: 0.8rem;
    color: rgba(244, 239, 230, 0.6);
    letter-spacing: 0.05em;
  }

  /* Quick Links */
  .quicklinks__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.2rem;
    margin-top: 2.5rem;
  }

  .ql-card {
    padding: 2rem;
    border: 1px solid var(--cream-dark);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }

  .ql-card:hover {
    border-color: var(--green-mid);
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.06);
  }

  .ql-card__icon { font-size: 2rem; color: var(--green-mid); }
  .ql-card__title { font-size: 1rem; font-weight: 600; color: var(--charcoal); }
  .ql-card__desc { font-size: 0.82rem; color: var(--gray); line-height: 1.5; }

  /* CTA */
  .cta__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-lg);
  }

  .cta__inner .section-body { margin-bottom: 0; }

  /* Responsive */
  @media (max-width: 1024px) {
    .herbs__grid { grid-template-columns: repeat(3, 1fr); }
    .quicklinks__grid { grid-template-columns: repeat(2, 1fr); }
    .philosophy__layout { grid-template-columns: 1fr; }
    .philosophy__gallery { grid-template-columns: 1fr 1fr; }
    .phi-img--bottle { display: none; }
  }

  @media (max-width: 768px) {
    .brand__grid { grid-template-columns: 1fr; }
    .herbs__grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .herb-card__circle { width: 120px; height: 120px; }
    .quicklinks__grid { grid-template-columns: 1fr; }
    .philosophy__gallery { grid-template-columns: 1fr; }
    .phi-img--scientist { height: 200px; }
    .phi-img--edelweiss { height: 200px; }
    .phi-img--overlay { display: none; }
    .stats__grid { justify-content: center; }
    .stat { min-width: 140px; }
    .cta__inner {
      flex-direction: column;
      text-align: center;
    }
    .cta__inner .section-body { margin: 0 auto; }
  }
</style>
