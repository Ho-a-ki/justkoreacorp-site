---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="사용 가이드" description="저스트코리아 제품 사용법을 안내합니다.">
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="page-hero__label">Usage Guide</p>
        <h1 class="page-hero__title">사용 가이드</h1>
        <p class="page-hero__desc">제품을 올바르게 사용하여 최대 효과를 누리세요.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="guide-list">
          {[
            {
              step: '01',
              title: '제품 선택',
              desc: '목적과 체질에 맞는 제품을 선택합니다. 허브 백과사전을 참고하여 나에게 맞는 허브를 확인하세요.'
            },
            {
              step: '02',
              title: '복용 시기',
              desc: '대부분의 제품은 식사 30분 전 또는 식후 1시간이 가장 효과적입니다. 제품별 안내를 꼭 확인하세요.'
            },
            {
              step: '03',
              title: '복용량',
              desc: '권장 복용량을 준수합니다. 처음 시작 시 소량부터 시작하여 몸의 반응을 확인하는 것을 권장합니다.'
            },
            {
              step: '04',
              title: '보관 방법',
              desc: '직사광선을 피하고 서늘하고 건조한 곳에 보관하세요. 개봉 후에는 가능한 빠른 시일 내에 사용하세요.'
            },
            {
              step: '05',
              title: '주의 사항',
              desc: '임산부, 수유 중인 분, 특정 질환이 있으신 분은 전문의와 상담 후 복용을 권장합니다.'
            },
          ].map(item => (
            <div class="guide-item">
              <span class="guide-item__step">{item.step}</span>
              <div class="guide-item__content">
                <h2 class="guide-item__title">{item.title}</h2>
                <p class="guide-item__desc">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--cream">
      <div class="container guide-cta">
        <h2>더 궁금하신가요?</h2>
        <p>제품 사용에 대한 더 자세한 문의는 연락처를 통해 상담받으실 수 있습니다.</p>
        <a href="/contact" class="btn-outline">문의하기 →</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .guide-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--cream-dark);
  }

  .guide-item {
    display: flex;
    align-items: flex-start;
    gap: 3rem;
    padding: 2.5rem 3rem;
    border-bottom: 1px solid var(--cream-dark);
    transition: background-color 0.2s;
  }

  .guide-item:last-child {
    border-bottom: none;
  }

  .guide-item:hover {
    background-color: var(--cream);
  }

  .guide-item__step {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--gold);
    font-style: italic;
    line-height: 1;
    flex-shrink: 0;
    width: 3rem;
  }

  .guide-item__title {
    font-size: 1.4rem;
    color: var(--green-deep);
    margin-bottom: 0.75rem;
  }

  .guide-item__desc {
    font-size: 0.95rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 640px;
  }

  .guide-cta {
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
  }

  .guide-cta h2 {
    font-size: 2rem;
    color: var(--green-deep);
    margin-bottom: 1rem;
  }

  .guide-cta p {
    font-size: 0.95rem;
    color: var(--gray);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .btn-outline {
    display: inline-block;
    padding: 0.9em 2em;
    border: 1px solid var(--green-deep);
    color: var(--green-deep);
    font-size: 0.85rem;
    border-radius: 2px;
    transition: all 0.2s;
  }

  .btn-outline:hover {
    background-color: var(--green-deep);
    color: var(--cream);
  }

  @media (max-width: 768px) {
    .guide-item {
      flex-direction: column;
      gap: 1rem;
      padding: 2rem;
    }
  }
</style>
