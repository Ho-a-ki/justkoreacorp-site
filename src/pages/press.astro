---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Press & Public" description="저스트코리아의 미디어 노출 및 인플루언서 활동을 소개합니다.">
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="page-hero__label">Press & Public</p>
        <h1 class="page-hero__title">Press &<br /><em>Public</em></h1>
        <p class="page-hero__desc">미디어, 유튜브, 인플루언서와 함께하는 저스트코리아의 이야기</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="press-tabs">
          <button class="press-tab is-active">전체</button>
          <button class="press-tab">언론</button>
          <button class="press-tab">유튜브</button>
          <button class="press-tab">인플루언서</button>
        </div>

        <div class="press-grid">
          {[
            { type: '유튜브', title: '허브로 건강한 삶 만들기', source: 'Just Korea 공식 채널', date: '2026.03' },
            { type: '언론', title: '자연 허브 시장의 새로운 강자', source: '헬스조선', date: '2026.02' },
            { type: '인플루언서', title: '일상에서 허브 활용하기', source: '@healthylife_kr', date: '2026.02' },
            { type: '유튜브', title: '허브 백과사전 시리즈', source: 'Just Korea 공식 채널', date: '2026.01' },
            { type: '언론', title: '건강한 삶을 위한 허브 선택법', source: '매일경제', date: '2026.01' },
            { type: '인플루언서', title: '저스트코리아 제품 리뷰', source: '@naturallife', date: '2025.12' },
          ].map(item => (
            <div class="press-card">
              <span class="press-card__type">{item.type}</span>
              <h3 class="press-card__title">{item.title}</h3>
              <div class="press-card__meta">
                <span class="press-card__source">{item.source}</span>
                <span class="press-card__date">{item.date}</span>
              </div>
              <a href="#" class="press-card__link">보러 가기 →</a>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .press-tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--cream-dark);
    padding-bottom: 1rem;
  }

  .press-tab {
    padding: 0.5em 1.2em;
    font-family: var(--font-body);
    font-size: 0.82rem;
    background: none;
    border: 1px solid var(--cream-dark);
    border-radius: 2px;
    cursor: pointer;
    color: var(--gray);
    transition: all 0.2s;
  }

  .press-tab.is-active,
  .press-tab:hover {
    background-color: var(--green-deep);
    color: var(--cream);
    border-color: var(--green-deep);
  }

  .press-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .press-card {
    border: 1px solid var(--cream-dark);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .press-card:hover {
    border-color: var(--green-mid);
    transform: translateY(-4px);
  }

  .press-card__type {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
  }

  .press-card__title {
    font-size: 1.1rem;
    color: var(--green-deep);
    line-height: 1.4;
    flex: 1;
  }

  .press-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.78rem;
    color: var(--gray);
  }

  .press-card__link {
    font-size: 0.82rem;
    color: var(--green-mid);
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.1em;
    display: inline-block;
    transition: color 0.2s;
  }

  .press-card__link:hover {
    color: var(--gold);
  }

  @media (max-width: 1024px) {
    .press-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .press-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
