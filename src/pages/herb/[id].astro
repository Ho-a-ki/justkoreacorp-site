---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import herbs from '../../data/herbs.json';

export function getStaticPaths() {
  return herbs.map(herb => ({ params: { id: herb.id } }));
}

const { id } = Astro.params;
const herb = herbs.find(h => h.id === id)!;
---

<BaseLayout title={herb.name} description={`${herb.name} — 허브 백과사전`}>
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <a href="/herb" class="back-link">← 허브 백과사전</a>
        <div class="hero-tags">
          {herb.tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
        <h1 class="page-hero__title">{herb.name}</h1>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="herb-content" set:html={herb.content} />
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.82rem;
    color: rgba(244, 239, 230, 0.6);
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--cream); }

  .hero-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .tag {
    font-size: 0.7rem;
    padding: 0.2em 0.8em;
    border: 1px solid rgba(184, 146, 74, 0.4);
    color: var(--gold);
    border-radius: 2px;
    letter-spacing: 0.08em;
  }

  .herb-content {
    max-width: 720px;
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.9;
    color: var(--charcoal);
  }

  .herb-content :global(h2) {
    font-size: 1.8rem;
    color: var(--green-deep);
    margin: 2.5rem 0 1rem;
    font-family: var(--font-display);
  }

  .herb-content :global(h3) {
    font-size: 1.4rem;
    color: var(--green-deep);
    margin: 2rem 0 0.75rem;
    font-family: var(--font-display);
  }

  .herb-content :global(h4) {
    font-size: 1.1rem;
    color: var(--green-deep);
    margin: 1.5rem 0 0.5rem;
  }

  .herb-content :global(p) {
    margin-bottom: 1.2rem;
    color: var(--charcoal);
  }

  .herb-content :global(ul),
  .herb-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.2rem;
  }

  .herb-content :global(li) {
    margin-bottom: 0.4rem;
  }

  .herb-content :global(blockquote) {
    border-left: 3px solid var(--gold);
    padding: 0.75rem 1.5rem;
    margin: 1.5rem 0;
    background-color: var(--cream);
    color: var(--gray);
  }

  .herb-content :global(hr) {
    border: none;
    border-top: 1px solid var(--cream-dark);
    margin: 2rem 0;
  }

  .herb-content :global(figure) {
    margin: 2rem 0;
  }

  .herb-content :global(img) {
    width: 100%;
    border-radius: 4px;
  }

  .herb-content :global(figcaption) {
    font-size: 0.82rem;
    color: var(--gray);
    text-align: center;
    margin-top: 0.5rem;
  }

  .herb-content :global(code) {
    background-color: var(--cream);
    padding: 0.1em 0.4em;
    border-radius: 2px;
    font-size: 0.9em;
  }

  .herb-content :global(.callout) {
    background-color: var(--cream);
    border-left: 3px solid var(--green-mid);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    border-radius: 0 4px 4px 0;
  }

  .herb-content :global(a) {
    color: var(--green-mid);
    text-decoration: underline;
  }
</style>
