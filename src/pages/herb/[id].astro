---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { queryDataSource, getPage, getPageBlocks } from '../../lib/notion';

export async function getStaticPaths() {
  const response = await queryDataSource('4f6d8d03-3a27-4cca-9007-06004a532702');
  return response.results.map((page: any) => ({
    params: { id: page.id },
  }));
}

const { id } = Astro.params;

const page = await getPage(id!) as any;
const props = page.properties;
const name = props['이름']?.title?.[0]?.plain_text ?? '';
const tags = props['태그']?.multi_select?.map((t: any) => t.name) ?? [];

const blocks = await getPageBlocks(id!);

// 블록 → HTML 변환
function renderRichText(richTexts: any[]): string {
  return richTexts.map(rt => {
    let text = rt.plain_text;
    if (rt.annotations?.bold) text = `<strong>${text}</strong>`;
    if (rt.annotations?.italic) text = `<em>${text}</em>`;
    if (rt.annotations?.underline) text = `<u>${text}</u>`;
    if (rt.annotations?.code) text = `<code>${text}</code>`;
    if (rt.href) text = `<a href="${rt.href}" target="_blank" rel="noopener">${text}</a>`;
    return text;
  }).join('');
}

function renderBlock(block: any): string {
  switch (block.type) {
    case 'paragraph':
      return `<p>${renderRichText(block.paragraph.rich_text)}</p>`;
    case 'heading_1':
      return `<h2>${renderRichText(block.heading_1.rich_text)}</h2>`;
    case 'heading_2':
      return `<h3>${renderRichText(block.heading_2.rich_text)}</h3>`;
    case 'heading_3':
      return `<h4>${renderRichText(block.heading_3.rich_text)}</h4>`;
    case 'bulleted_list_item':
      return `<li>${renderRichText(block.bulleted_list_item.rich_text)}</li>`;
    case 'numbered_list_item':
      return `<li>${renderRichText(block.numbered_list_item.rich_text)}</li>`;
    case 'quote':
      return `<blockquote>${renderRichText(block.quote.rich_text)}</blockquote>`;
    case 'divider':
      return `<hr />`;
    case 'image': {
      const url = block.image.type === 'external'
        ? block.image.external.url
        : block.image.file.url;
      const caption = block.image.caption?.[0]?.plain_text ?? '';
      return `<figure><img src="${url}" alt="${caption}" />${caption ? `<figcaption>${caption}</figcaption>` : ''}</figure>`;
    }
    case 'callout':
      return `<div class="callout">${block.callout.icon?.emoji ?? ''} ${renderRichText(block.callout.rich_text)}</div>`;
    default:
      return '';
  }
}

// 리스트 아이템 묶기
let html = '';
let inBulletList = false;
let inNumberedList = false;

for (const block of blocks) {
  if (block.type === 'bulleted_list_item') {
    if (!inBulletList) { html += '<ul>'; inBulletList = true; }
    html += renderBlock(block);
  } else {
    if (inBulletList) { html += '</ul>'; inBulletList = false; }
    if (block.type === 'numbered_list_item') {
      if (!inNumberedList) { html += '<ol>'; inNumberedList = true; }
      html += renderBlock(block);
    } else {
      if (inNumberedList) { html += '</ol>'; inNumberedList = false; }
      html += renderBlock(block);
    }
  }
}
if (inBulletList) html += '</ul>';
if (inNumberedList) html += '</ol>';
---

<BaseLayout title={name} description={`${name} — 허브 백과사전`}>
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <a href="/herb" class="back-link">← 허브 백과사전</a>
        <div class="hero-tags">
          {tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
        <h1 class="page-hero__title">{name}</h1>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="herb-content" set:html={html} />
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.82rem;
    color: rgba(244, 239, 230, 0.6);
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--cream); }

  .hero-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .tag {
    font-size: 0.7rem;
    padding: 0.2em 0.8em;
    border: 1px solid rgba(184, 146, 74, 0.4);
    color: var(--gold);
    border-radius: 2px;
    letter-spacing: 0.08em;
  }

  .herb-content {
    max-width: 720px;
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.9;
    color: var(--charcoal);
  }

  .herb-content :global(h2) {
    font-size: 1.8rem;
    color: var(--green-deep);
    margin: 2.5rem 0 1rem;
    font-family: var(--font-display);
  }

  .herb-content :global(h3) {
    font-size: 1.4rem;
    color: var(--green-deep);
    margin: 2rem 0 0.75rem;
    font-family: var(--font-display);
  }

  .herb-content :global(h4) {
    font-size: 1.1rem;
    color: var(--green-deep);
    margin: 1.5rem 0 0.5rem;
  }

  .herb-content :global(p) {
    margin-bottom: 1.2rem;
    color: var(--charcoal);
  }

  .herb-content :global(ul),
  .herb-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.2rem;
  }

  .herb-content :global(li) {
    margin-bottom: 0.4rem;
  }

  .herb-content :global(blockquote) {
    border-left: 3px solid var(--gold);
    padding: 0.75rem 1.5rem;
    margin: 1.5rem 0;
    background-color: var(--cream);
    color: var(--gray);
  }

  .herb-content :global(hr) {
    border: none;
    border-top: 1px solid var(--cream-dark);
    margin: 2rem 0;
  }

  .herb-content :global(figure) {
    margin: 2rem 0;
  }

  .herb-content :global(img) {
    width: 100%;
    border-radius: 4px;
  }

  .herb-content :global(figcaption) {
    font-size: 0.82rem;
    color: var(--gray);
    text-align: center;
    margin-top: 0.5rem;
  }

  .herb-content :global(code) {
    background-color: var(--cream);
    padding: 0.1em 0.4em;
    border-radius: 2px;
    font-size: 0.9em;
  }

  .herb-content :global(.callout) {
    background-color: var(--cream);
    border-left: 3px solid var(--green-mid);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    border-radius: 0 4px 4px 0;
  }

  .herb-content :global(a) {
    color: var(--green-mid);
    text-decoration: underline;
  }
</style>
