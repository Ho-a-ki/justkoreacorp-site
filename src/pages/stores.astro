---
import { Client } from '@notionhq/client';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const notion = new Client({ auth: import.meta.env.NOTION_API_KEY });

const DATA_SOURCE_ID = 'f5081f2a-6393-44a4-9f8c-2bedaa2bb2a0';

const response = await notion.dataSources.query({
  data_source_id: DATA_SOURCE_ID,
  sorts: [{ property: '이름', direction: 'ascending' }],
});

const stores = response.results.map((page: any) => {
  const props = page.properties;
  return {
    id: page.id,
    name: props['이름']?.title?.[0]?.plain_text ?? '',
    address: props['주소']?.rich_text?.[0]?.plain_text ?? '',
    phone: props['전화']?.rich_text?.[0]?.plain_text ?? '',
    tag: props['태그']?.select?.name ?? '',
    type: props['매장유형']?.select?.name ?? '',
    spa: props['스파 여부']?.select?.name ?? '',
  };
});
---

<BaseLayout title="스토어" description="저스트코리아 스토어 위치와 운영 정보를 안내합니다.">
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="page-hero__label">Stores</p>
        <h1 class="page-hero__title">스토어</h1>
        <p class="page-hero__desc">가까운 저스트코리아 스토어를 방문해보세요.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        {stores.length === 0 ? (
          <p class="empty">등록된 스토어가 없습니다.</p>
        ) : (
          <div class="store-grid">
            {stores.map(store => (
              <div class="store-card">
                <div class="store-card__top">
                  {store.tag && <p class="store-card__region">{store.tag}</p>}
                  <div class="store-card__badges">
                    {store.type && <span class="badge badge--type">{store.type}</span>}
                    {store.spa && <span class="badge badge--spa">스파</span>}
                  </div>
                </div>
                <h2 class="store-card__name">{store.name}</h2>
                <div class="store-card__info">
                  {store.address && <p>📍 {store.address}</p>}
                  {store.phone && <p>📞 {store.phone}</p>}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .store-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .store-card {
    border: 1px solid var(--cream-dark);
    padding: 2rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .store-card:hover {
    border-color: var(--green-mid);
    transform: translateY(-4px);
  }

  .store-card__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .store-card__region {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
  }

  .store-card__badges {
    display: flex;
    gap: 0.4rem;
  }

  .badge {
    font-size: 0.65rem;
    padding: 0.2em 0.6em;
    border-radius: 2px;
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .badge--type {
    background-color: var(--cream-dark);
    color: var(--charcoal);
  }

  .badge--spa {
    background-color: var(--green-deep);
    color: #ffffff;
  }

  .store-card__name {
    font-size: 1.6rem;
    color: var(--green-deep);
    margin-bottom: 1.25rem;
  }

  .store-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--gray);
    line-height: 1.6;
  }

  .empty {
    color: var(--gray);
    font-size: 0.95rem;
  }

  @media (max-width: 1024px) {
    .store-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .store-grid { grid-template-columns: 1fr; }
  }
</style>
