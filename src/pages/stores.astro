---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import stores from '../data/stores.json';
---

<BaseLayout title="스토어" description="유스트코리아 스토어 위치와 운영 정보를 안내합니다.">
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="page-hero__label">Stores</p>
        <h1 class="page-hero__title">스토어</h1>
        <p class="page-hero__desc">가까운 유스트코리아 스토어를 방문해보세요.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        {stores.length === 0 ? (
          <p class="empty">등록된 스토어가 없습니다.</p>
        ) : (
          <div class="store-grid">
            {stores.map(store => (
              <div class="store-card">
                <div class="store-card__header">
                  <h3 class="store-card__name">{store.name}</h3>
                  <div class="store-card__badges">
                    {store.tag && <span class="store-badge">{store.tag}</span>}
                    {store.spa === '있음' && <span class="store-badge store-badge--spa">SPA</span>}
                  </div>
                </div>
                <div class="store-card__body">
                  {store.address && (
                    <p class="store-card__info">
                      <span class="material-symbols-outlined">location_on</span>
                      {store.address}
                    </p>
                  )}
                  {store.phone && (
                    <p class="store-card__info">
                      <span class="material-symbols-outlined">call</span>
                      {store.phone}
                    </p>
                  )}
                  {store.type && (
                    <p class="store-card__info">
                      <span class="material-symbols-outlined">storefront</span>
                      {store.type}
                    </p>
                  )}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .store-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }

  .store-card {
    border: 1px solid var(--cream-dark);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .store-card:hover {
    border-color: var(--green-light);
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }

  .store-card__header {
    padding: 1.2rem 1.2rem 0.8rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .store-card__name {
    font-size: 1rem;
    color: var(--green-deep);
  }

  .store-card__badges {
    display: flex;
    gap: 0.3rem;
  }

  .store-badge {
    font-size: 0.6rem;
    padding: 0.15em 0.5em;
    border-radius: 2px;
    background-color: var(--cream);
    color: var(--green-mid);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .store-badge--spa {
    background-color: var(--green-mid);
    color: #fff;
  }

  .store-card__body {
    padding: 0 1.2rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .store-card__info {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--gray);
  }

  .store-card__info .material-symbols-outlined {
    font-size: 1rem;
    color: var(--green-mid);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .empty {
    color: var(--gray);
    font-size: 0.95rem;
  }

  @media (width <= 1024px) {
    .store-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (width <= 640px) {
    .store-grid { grid-template-columns: 1fr; }
  }
</style>
