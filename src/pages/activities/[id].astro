---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import activities from '../../data/activities.json';

export function getStaticPaths() {
  return activities.map(a => ({ params: { id: a.id } }));
}

const { id } = Astro.params;
const activity = activities.find(a => a.id === id)!;

const formattedDate = activity.date
  ? new Date(activity.date).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
---

<BaseLayout title={activity.title} description={activity.summary || activity.title}>
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <a href="/activities" class="back-link">← 주요 활동</a>
        <div class="hero-meta">
          {formattedDate && <span class="hero-date">{formattedDate}</span>}
          {activity.category && <span class="hero-cat">{activity.category}</span>}
        </div>
        <h1 class="page-hero__title">{activity.title}</h1>
        {activity.summary && <p class="page-hero__desc">{activity.summary}</p>}
      </div>
    </section>

    <section class="section">
      <div class="container">
        <article class="activity-content" set:html={activity.content} />
        <div class="article-footer">
          <a href="/activities" class="back-btn">← 목록으로</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.82rem;
    color: rgba(244, 239, 230, 0.6);
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--cream); }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .hero-date {
    font-size: 0.8rem;
    color: rgba(244, 239, 230, 0.6);
    letter-spacing: 0.05em;
  }

  .hero-cat {
    font-size: 0.68rem;
    padding: 0.2em 0.7em;
    border: 1px solid rgba(210, 172, 83, 0.4);
    color: var(--gold);
    border-radius: 2px;
    letter-spacing: 0.08em;
  }

  .activity-content {
    max-width: 720px;
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.9;
    color: var(--charcoal);
  }

  .activity-content :global(h2) { font-size: 1.8rem; color: var(--green-deep); margin: 2.5rem 0 1rem; font-family: var(--font-display); }
  .activity-content :global(h3) { font-size: 1.4rem; color: var(--green-deep); margin: 2rem 0 0.75rem; font-family: var(--font-display); }
  .activity-content :global(h4) { font-size: 1.1rem; color: var(--green-deep); margin: 1.5rem 0 0.5rem; }
  .activity-content :global(p) { margin-bottom: 1.2rem; }
  .activity-content :global(ul), .activity-content :global(ol) { padding-left: 1.5rem; margin-bottom: 1.2rem; }
  .activity-content :global(li) { margin-bottom: 0.4rem; }
  .activity-content :global(blockquote) { border-left: 3px solid var(--gold); padding: 0.75rem 1.5rem; margin: 1.5rem 0; background-color: var(--cream); color: var(--gray); }
  .activity-content :global(hr) { border: none; border-top: 1px solid var(--cream-dark); margin: 2rem 0; }
  .activity-content :global(figure) { margin: 2rem 0; }
  .activity-content :global(img) { width: 100%; border-radius: 4px; }
  .activity-content :global(figcaption) { font-size: 0.82rem; color: var(--gray); text-align: center; margin-top: 0.5rem; }
  .activity-content :global(.callout) { background-color: var(--cream); border-left: 3px solid var(--green-mid); padding: 1rem 1.5rem; margin: 1.5rem 0; border-radius: 0 4px 4px 0; }
  .activity-content :global(a) { color: var(--green-mid); text-decoration: underline; }

  .article-footer {
    max-width: 720px;
    margin: 3rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--cream-dark);
  }

  .back-btn {
    font-size: 0.85rem;
    color: var(--green-mid);
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.1em;
    transition: color 0.2s;
  }
  .back-btn:hover { color: var(--gold); }
</style>
